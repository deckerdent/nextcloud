# Ignore all .env files
.env*

# But do not ignore the example template
!.env.example

# Keep directory trees but ignore generated/runtime files

# Nextcloud config (runtime, not committed)
/deployment/config/nextcloud/*
!/deployment/config/nextcloud/.gitkeep

# SWAG config (runtime, not committed)
/deployment/config/swag/config/*
!/deployment/config/swag/config/.gitkeep

# SWAG generated certs (never commit private keys)
/deployment/config/swag/config/etc/

# Nextcloud data volume
/deployment/nextcloud-data/*
!/deployment/nextcloud-data/.gitkeep

# Database volume
/deployment/db-data/*
!/deployment/db-data/.gitkeep